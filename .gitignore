# lives in Dolt; do not ship the tracker to public remotes.
.beads/
.beads-credential-key
.dolt/
*.db

# Local store artifacts (SQLite adapter dev DBs).
*.sqlite
*.sqlite3

# Private design/spec material not for the public mirror.
docs/design/private-*.md

# Root-built binaries.
/nagus
/*-connector

# Editor / OS cruft.
*.log
.DS_Store
